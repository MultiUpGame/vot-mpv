#!/bin/bash
# Helper: formats yt-dlp search results with vot library markers.
# Usage: ytv-fmt [results-file]   (no arg = read from stdin)

LIBRARY="$HOME/.local/share/vot-mpv/library.json"
INPUT="${1:-/dev/stdin}"

while IFS=$'\t' read -r id title uploader duration; do
  [ -z "$id" ] && continue
  if grep -q "\"$id\"" "$LIBRARY" 2>/dev/null; then
    marker="★"
  else
    marker=" "
  fi
  printf "%s  %-8s  %-22s  %s\t%s\n" \
    "$marker" \
    "${duration:--:--}" \
    "${uploader:0:22}" \
    "$title" \
    "$id"
done < "$INPUT"
